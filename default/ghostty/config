# Kitana managed Ghostty config

# Theme
theme = catppuccin

# ncurses calls it ghostty, not xterm-ghostty
#term = "ghostty"

# Font
font-family = "Berkeley Mono Variable"
font-style = Regular
font-size = 12

# Appearance
window-padding-x = 8
window-padding-y = 4
# background-opacity = 0.99
cursor-style = "block"
cursor-style-blink = false

confirm-close-surface=false
resize-overlay = never

# Cursor styling + SSH session terminfo
# -- options must be passed together
shell-integration-features = no-cursor,ssh-terminfo,ssh-env

# Bindings
keybind = ctrl+shift+h=unbind
keybind = ctrl+shift+j=unbind
keybind = ctrl+shift+k=unbind
keybind = ctrl+shift+l=unbind
keybind = ctrl+shift+o=unbind

# -- window management
keybind = ctrl+w>q=close_surface
keybind = ctrl+w>h=new_split:left
keybind = ctrl+w>k=new_split:up
keybind = ctrl+w>j=new_split:down
keybind = ctrl+w>l=new_split:right

keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+l=goto_split:right

# -- define "resize" key table
keybind = resize/
keybind = resize/catch_all=ignore
keybind = ctrl+shift+r=activate_key_table:resize
keybind = resize/escape=deactivate_key_table

# resize actions
keybind = resize/left=resize_split:left,25
keybind = resize/up=resize_split:up,25
keybind = resize/down=resize_split:down,25
keybind = resize/right=resize_split:right,25

# -- clipboard
keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = performable:ctrl+alt+x=paste_from_selection

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on Hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
