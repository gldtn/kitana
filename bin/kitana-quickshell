#!/bin/bash

set -euo pipefail

config_name="kitana"
config_file="$HOME/.config/quickshell/$config_name/shell.qml"
log_file="/tmp/kitana-quickshell.log"

export QS_NO_RELOAD_POPUP=1

if ! command -v quickshell >/dev/null 2>&1; then
  exit 0
fi

if pgrep -x quickshell >/dev/null 2>&1; then
  touch "$config_file"
  command -v notify-send >/dev/null 2>&1 && notify-send "Kitana" "Quickshell reload requested" >/dev/null 2>&1 || true
  exit 0
fi

command -v notify-send >/dev/null 2>&1 && notify-send "Kitana" "Starting Quickshell" >/dev/null 2>&1 || true
exec quickshell --daemonize --no-duplicate --config "$config_name" >"$log_file" 2>&1
