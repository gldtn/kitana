#!/usr/bin/env bash

set -euo pipefail

BROWSER="brave"
CONFIG_FILE="$HOME/.config/webapp-install.conf"

if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
fi

APP_URL="${1:-}"
APP_NAME="${2:-Web App}"

if [ -z "$APP_URL" ]; then
  echo "Usage: webapp-launch <url> [name]"
  exit 1
fi

exec "$BROWSER" --new-window --ozone-platform=wayland --app="$APP_URL" --name="$APP_NAME" --class="$APP_NAME"
