#!/bin/bash

set -euo pipefail

if ! command -v hyprctl >/dev/null 2>&1; then
  exit 0
fi

monitors_json="$(hyprctl monitors -j)"

python - "$monitors_json" <<'PY' | while IFS= read -r rule; do
import json
import sys

monitors = json.loads(sys.argv[1])
monitors = [monitor for monitor in monitors if not monitor.get("disabled")]
monitors.sort(key=lambda monitor: (monitor.get("x", 0), monitor.get("id", 0)))

if not monitors:
    sys.exit(0)

def emit(workspace, monitor):
    print(f'{workspace}\t{monitor["name"]}')

if len(monitors) == 1:
    for workspace in range(1, 11):
        emit(workspace, monitors[0])
else:
    for workspace in range(1, 6):
        emit(workspace, monitors[0])
    for workspace in range(6, 11):
        emit(workspace, monitors[1])
PY
  workspace="${rule%%$'\t'*}"
  monitor="${rule#*$'\t'}"
  hyprctl eval "hl.workspace_rule({ workspace = \"$workspace\", monitor = \"$monitor\", persistent = true })" >/dev/null 2>&1 || true
done

active_workspace="$(hyprctl activeworkspace -j | python -c 'import json, sys; print(json.load(sys.stdin).get("id", 1))' 2>/dev/null || printf '1')"

if [ "$active_workspace" -lt 1 ] || [ "$active_workspace" -gt 10 ]; then
  hyprctl dispatch 'hl.dsp.focus({ workspace = 1 })' >/dev/null 2>&1 || true
fi
