#!/bin/bash

set -euo pipefail

source_value="${1:-$HOME/.config/hypr/walls/mystical_night_town_default.jpg}"
target="$HOME/.config/quickshell/kitana/Colors.qml"
mkdir -p "$(dirname "$target")"

if [[ "$source_value" =~ ^#?[0-9a-fA-F]{6}$ ]]; then
  color="#${source_value#\#}"
  python - "$color" "$target" <<'PY'
import colorsys
import pathlib
import sys

source = sys.argv[1]
target = pathlib.Path(sys.argv[2])

r, g, b = (int(source[i:i + 2], 16) / 255 for i in (1, 3, 5))
h, l, s = colorsys.rgb_to_hls(r, g, b)

def hex_color(lightness, saturation=None):
    rr, gg, bb = colorsys.hls_to_rgb(h, lightness, s if saturation is None else saturation)
    return "#{:02x}{:02x}{:02x}".format(round(rr * 255), round(gg * 255), round(bb * 255))

target.write_text(f'''// Kitana managed Quickshell colors

pragma Singleton

import QtQuick

QtObject {{
  readonly property color background: "{hex_color(0.10, max(s * 0.45, 0.12))}"
  readonly property color surface: "{hex_color(0.16, max(s * 0.40, 0.10))}"
  readonly property color surfaceAlt: "{hex_color(0.24, max(s * 0.40, 0.10))}"
  readonly property color foreground: "#f4f4f5"
  readonly property color muted: "#a1a1aa"
  readonly property color accent: "{source}"
  readonly property color accentText: "#111111"
  readonly property color warning: "#f9e2af"
  readonly property color danger: "#f38ba8"
}}
''')
PY
  echo "Generated $target from $color"
  exit 0
fi

if ! command -v matugen >/dev/null 2>&1; then
  echo "matugen is not installed; pass a hex color like '#89b4fa' instead"
  exit 1
fi

if [ ! -f "$source_value" ]; then
  echo "wallpaper not found: $source_value"
  exit 1
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

if ! matugen image "$source_value" --json hex >"$tmpdir/colors.json"; then
  echo "matugen failed; pass a hex color like '#89b4fa' to generate Kitana bar colors without matugen"
  exit 1
fi

python - "$tmpdir/colors.json" "$target" <<'PY'
import json
import pathlib
import sys

data = json.loads(pathlib.Path(sys.argv[1]).read_text())
colors = data.get("colors", data)
dark = colors.get("dark", colors)

def get(name, fallback):
    return dark.get(name, fallback)

pathlib.Path(sys.argv[2]).write_text(f'''// Kitana managed Quickshell colors

pragma Singleton

import QtQuick

QtObject {{
  readonly property color background: "{get("background", "#1e1e2e" )}"
  readonly property color surface: "{get("surface_container", "#313244" )}"
  readonly property color surfaceAlt: "{get("surface_container_high", "#45475a" )}"
  readonly property color foreground: "{get("on_background", "#cdd6f4" )}"
  readonly property color muted: "{get("on_surface_variant", "#9399b2" )}"
  readonly property color accent: "{get("primary", "#89b4fa" )}"
  readonly property color accentText: "{get("on_primary", "#11111b" )}"
  readonly property color warning: "{get("tertiary", "#f9e2af" )}"
  readonly property color danger: "{get("error", "#f38ba8" )}"
}}
''')
PY

echo "Generated $target"
