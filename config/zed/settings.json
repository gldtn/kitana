{
  "git_panel": {
    "dock": "left"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "context_servers": {
    "arch-ops-server": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.3-codex",
      "enable_thinking": true
    },
    "favorite_models": [
      {
        "provider": "openai",
        "model": "gpt-5.3-codex",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "opencode": {
      "type": "custom",
      "command": "opencode",
      "args": [
        "acp"
      ]
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "php": true,
    "blade": true,
    "env": true,
    "tailwindcss": true
  },
  "theme": "Catppuccin Mocha",
  "icon_theme": "Flow Light",
  "buffer_font_family": "Berkeley Mono Variable",
  "buffer_font_size": 16,
  "ui_font_size": 18,
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "none",
  "preferred_line_length": 160,
  "show_wrap_guides": true,
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "formatter": "language_server",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "fixed",
    "background_coloring": "disabled"
  },
  "experimental.theme_overrides": {
    "editor.document_highlight.bracket_background": "#00000000"
  },
  "languages": {
    "Lua": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}",
            "-"
          ]
        }
      }
    },
    "PHP": {
      "tab_size": 4,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "cat > {buffer_path} && ./vendor/bin/pint --quiet {buffer_path} && cat {buffer_path}"
          ]
        }
      },
      "language_servers": [
        "intelephense",
        "..."
      ]
    },
    "Blade": {
      "tab_size": 4,
      "hard_tabs": false,
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "Vue.js": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "CSS": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on"
    }
  },
  "lsp": {
    "intelephense": {
      "settings": {
        "intelephense.files.associations": [
          "*.php",
          "*.blade.php"
        ],
        "intelephense.environment.phpVersion": "8.4.0",
        "intelephense.stubs": [
          "apache",
          "bcmath",
          "bz2",
          "calendar",
          "com_dotnet",
          "Core",
          "ctype",
          "curl",
          "date",
          "dba",
          "dom",
          "enchant",
          "exif",
          "FFI",
          "fileinfo",
          "filter",
          "fpm",
          "ftp",
          "gd",
          "gettext",
          "gmp",
          "hash",
          "iconv",
          "imap",
          "intl",
          "json",
          "ldap",
          "libxml",
          "mbstring",
          "meta",
          "mysqli",
          "oci8",
          "odbc",
          "openssl",
          "pcntl",
          "pcre",
          "PDO",
          "pdo_ibm",
          "pdo_mysql",
          "pdo_pgsql",
          "pdo_sqlite",
          "pgsql",
          "Phar",
          "posix",
          "pspell",
          "readline",
          "Reflection",
          "session",
          "shmop",
          "SimpleXML",
          "snmp",
          "soap",
          "sockets",
          "sodium",
          "SPL",
          "sqlite3",
          "standard",
          "superglobals",
          "sysvmsg",
          "sysvsem",
          "sysvshm",
          "tidy",
          "tokenizer",
          "xml",
          "xmlreader",
          "xmlrpc",
          "xmlwriter",
          "xsl",
          "Zend OPcache",
          "zip",
          "zlib"
        ]
      }
    }
  },
  "file_types": {
    "Blade": [
      "blade.php"
    ],
    "Dockerfile": [
      "Dockerfile",
      "Dockerfile.*"
    ]
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600
    }
  },
  "terminal": {
    "shell": {
      "program": "/bin/bash"
    },
    "font_family": "Berkeley Mono Variable",
    "font_size": 14,
    "working_directory": "current_project_directory"
  },
  "project_panel": {
    "dock": "right",
    "default_width": 340
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 340
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true
  },
  "scrollbar": {
    "show": "system",
    "git_diff": true,
    "diagnostics": "error",
  },
  "minimap": {
    "show": "never",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": null
  },
  "hover_popover_enabled": true,
  "hover_popover_delay": 600,
  "vertical_scroll_margin": 3,
  "relative_line_numbers": "disabled",
  "seed_search_query_from_cursor": "always",
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": [
      ".env"
    ]
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": false,
  "autosave": "off",
  "auto_update": false,
  "journal": {
    "hour_format": "hour12"
  }
}
